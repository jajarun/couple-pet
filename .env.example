# docker compose 环境变量：复制成 .env 按需改；留空即用下面的默认。
#   cp .env.example .env

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=petgame
MYSQL_USER=petgame
MYSQL_PASSWORD=petgame
DB_PORT=3306

# ---------- 后端 ----------
BACKEND_PORT=8000
JWT_SECRET=dev-secret-change-me
DAILY_CHAT_CAP=50

# DeepSeek：留空 = 离线沙雕兜底；填了 key 才走真 AI（key 只在服务端）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- 前端入口（nginx）----------
# 80 = 手机可直接用 http://<域名>（无需 :端口）；改回 8080 可避免和其它占 80 的服务冲突
WEB_PORT=80
