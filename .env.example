# docker compose 环境变量：复制成 .env 按需改；留空即用下面的默认。
#   cp .env.example .env

# ---------- MySQL ----------
MYSQL_ROOT_PASSWORD=rootpw
MYSQL_DATABASE=petgame
MYSQL_USER=petgame
MYSQL_PASSWORD=petgame
DB_PORT=3306

# ---------- 后端 ----------
BACKEND_PORT=8000
JWT_SECRET=dev-secret-change-me
DAILY_CHAT_CAP=50

# 构建时 pip 镜像：国内服务器填了提速；留空 = 官方 pypi
# 例：PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_INDEX_URL=

# 基础镜像 tag：默认 3.13-slim；机器拉不动 Docker Hub 但本地已缓存别的 tag 时指过去
# 例：PYTHON_TAG=3.12-slim
PYTHON_TAG=3.13-slim

# DeepSeek：留空 = 离线沙雕兜底；填了 key 才走真 AI（key 只在服务端）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---------- 玩法参数 ----------
# 多久没打心跳就算「TA 下线了」。前端每 10 秒打一次 POST /presence，留 2.5 倍冗余。
# 同框期间所有互动数值 ×2，并解锁「摸摸头」。
PRESENCE_TTL_SECONDS=25
# 剧情副本每章有几幕带选项（之后再加一幕结局）。
STORY_ROUNDS=4

# ---------- 后台定时任务 ----------
# 总开关。玩法 job（分身梦话）不依赖推送配置，没 VAPID 也照跑。
# 离家出走没有 job——「1 小时内骂满 5 次」在第 5 次骂落库时当场生效（见 routers/actions.py）。
# 注意：scheduler 跑在 uvicorn 进程内，依赖单 worker（多 worker 会重复触发）。
ENABLE_SCHEDULER=true
# 每天几点（UTC+8）生成「昨夜梦话」并推送。别挪到半夜——推送会在手机上响。
DREAM_HOUR=8

# Web Push（VAPID）：留空 = 关闭消息推送 + 不挂「火苗将熄 / 每日一问催答」这类提醒 job。
# 生成一对密钥：cd backend && ./.venv/bin/python -m app.gen_vapid（见 README）。
# 公钥前端走 GET /api/push/public-key 拿，无需单独配前端；私钥只在服务端。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:leosmith16879@gmail.com
STREAK_REMINDER_HOUR=20
# 每日一问催答时刻（UTC+8 整点，逗号分隔；留空=关闭该催答）：默认早 10 点、下午 2 点各一次。
DAILY_REMINDER_HOURS=10,14

# ---------- 前端入口（nginx）----------
# 80 = 手机可直接用 http://<域名>（无需 :端口）；改回 8080 可避免和其它占 80 的服务冲突
WEB_PORT=80
